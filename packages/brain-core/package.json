  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "cline",
    "ai-tools",
    "ipc",
    "named-pipes",
    "synapse-network",
    "developer-tools",
    "hebbian-learning",
    "shared-infrastructure"
