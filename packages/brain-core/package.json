  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/timmeck/brain-ecosystem",
    "directory": "packages/brain-core"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
